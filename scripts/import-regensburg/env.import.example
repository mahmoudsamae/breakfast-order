# Copy to env.import (do not commit secrets)
#
# Live importer (import-breakfast-data.mjs): set OLD + NEW below.
# CSV importer (import-from-export.mjs): only NEW_DATABASE_URL (+ REGENSBURG_SLUG) required; OLD ignored.

# OLD DATABASE — use a read-only role if possible (SELECT only)
# Use whatever URL reaches legacy Postgres (direct host:port). Localhost = no forced SSL.

OLD_DATABASE_URL=postgresql://readonly_user:password@old-host:5432/old_dbname

# NEW DATABASE — service_role or user with INSERT on breakfast tables
# Prefer Supabase Direct or Session pooler on port 5432 (URI from Settings → Database).
# Avoid transaction pooler :6543 for this importer — see README.

NEW_DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Optional:
# PG_CONNECT_TIMEOUT_MS=60000
# SUPABASE_SSL_STRICT=1
# PGSSLMODE=disable
# OLD_PGSSLMODE=disable
# NEW_PGSSLMODE=disable
# EXPORT_DIR=scripts/import-regensburg/export

# Existing branch slug in NEW (must already exist)

REGENSBURG_SLUG=regensburg

# Optional: if OLD DB already has branch_id (multi-tenant legacy), set the Regensburg row id to copy only that tenant

# OLD_BRANCH_ID=1
